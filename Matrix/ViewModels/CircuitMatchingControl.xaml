<UserControl x:Class="Matrix.Controls.CircuitMatchingControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Matrix.ViewModels"
             x:DataType="vm:NetworkAnalyzerViewModel">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="+ Series L" Margin="2" Padding="5,2"/>
            <Button Content="+ Shunt C" Margin="2" Padding="5,2"/>
        </StackPanel>

        <!-- 매칭 소자 리스트 표시 영역 -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding MatchingCircuit}" Margin="5">
            <!-- TODO: 각 소자(CircuitComponent)를 시각적으로 표현할 DataTemplate 작성 -->
        </ItemsControl>
    </Grid>
</UserControl>
