<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Matrix.Views"
        xmlns:controls="using:Matrix.Controls"
        xmlns:vm="using:Matrix.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="Matrix.Views.MainWindow"
        x:DataType="vm:NetworkAnalyzerViewModel"
        Title="Network Analyzer"
        >

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="2*,1.2*">
            <Grid Grid.Column="0" Margin="10" RowDefinitions="Auto,*,Auto">
                <Button Grid.Row="0" Content="Save as PNG..." Click="OnSaveChartClick" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                <controls:SmithChartControl Grid.Row="1" 
                                         Name="MainSmithChart"
                                         MeasuredData="{Binding MeasuredData}"
                                         MatchedData="{Binding MatchedData}"
                                         MatchingPaths="{Binding MatchingPaths}"
                                         ShowVswrCircle="{Binding ShowVswrCircle}"
                                         TargetVswr="{Binding TargetVswr}"/>
                <controls:SchematicControl Grid.Row="2"
                                          Circuit="{Binding MatchingCircuit}"
                                          Height="180"
                                          Margin="0,10,0,0"/>
            </Grid>

            <views:CircuitMatchingControl Grid.Column="1" Margin="10" DataContext="{Binding}"/>
        </Grid>
        
        <!-- Metrics Panel -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" Spacing="30" HorizontalAlignment="Center">
                <TextBlock Text="{Binding VswrText}" FontWeight="SemiBold" FontSize="15" Foreground="#333333"/>
                <TextBlock Text="{Binding ReturnLossText}" FontWeight="SemiBold" FontSize="15" Foreground="#333333"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>